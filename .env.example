# =====================================================
# NEUROTRADE — frontend environment
# These are baked into the bundle at build time.
# =====================================================

# In dev, leave these empty — Vite proxies /api and /ws to the backend.
# In production, set them to the deployed backend URL.
# VITE_API_URL=https://api.neurotrade.com/api
# VITE_WS_URL=wss://api.neurotrade.com/ws

# Used only by vite dev proxy (defaults to http://localhost:4000)
# VITE_BACKEND_URL=http://localhost:4000

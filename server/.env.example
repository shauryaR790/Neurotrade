# =====================================================
# NEUROTRADE — server environment
# Copy this file to .env and fill in values.
# Everything is optional — defaults make the app work locally.
# =====================================================

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Auth — generate a real secret in prod (e.g. `openssl rand -hex 64`)
JWT_SECRET=neurotrade_dev_secret_change_me
JWT_EXPIRES_IN=7d

# Database (lowdb JSON file) — relative to server/
DATA_FILE=./data/neurotrade.json

# OpenAI (optional — fallback responder used if absent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Market data (no keys required for crypto / simulated stocks)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
COINGECKO_API_URL=https://api.coingecko.com/api/v3
